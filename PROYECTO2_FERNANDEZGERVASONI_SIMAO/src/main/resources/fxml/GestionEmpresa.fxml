<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="card" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.GestionEmpresaController">
   <padding>
      <Insets bottom="15" left="15" right="15" top="15" />
   </padding>
   <children>
      <HBox spacing="10">
         <children>
            <HBox fx:id="boxBuscar" HBox.hgrow="ALWAYS">
               <children>
                  <TextField fx:id="txtBuscador" onAction="#buscar" promptText="Buscar empresa..." HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            <HBox fx:id="boxNuevo" managed="false" visible="false" HBox.hgrow="ALWAYS">
               <children>
                  <VBox spacing="10" styleClass="form" HBox.hgrow="ALWAYS">
                     <children>
                        <TextField fx:id="txtNombre" promptText="Nombre" />
                        <Label fx:id="lblNombreError" managed="false" styleClass="error-label" visible="false" />
                        <TextField fx:id="txtDireccion" promptText="Dirección" />
                        <HBox spacing="10">
                           <children>
                              <Button onAction="#switchNuevo" styleClass="btn-primary" text="Guardar" />
                              <Button onAction="#switchBuscar" styleClass="btn-secondary" text="Cancelar" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox fx:id="boxEditar" managed="false" visible="false" HBox.hgrow="ALWAYS">
               <children>
                  <VBox spacing="10" styleClass="form" HBox.hgrow="ALWAYS">
                     <children>
                        <ComboBox fx:id="cbEditarEmpresa" prefWidth="250" promptText="Selecciona empresa" />
                        <TextField fx:id="txtEditNombre" promptText="Nombre" />
                        <Label fx:id="lblEditNombreError" managed="false" styleClass="error-label" visible="false" />
                        <TextField fx:id="txtEditDireccion" promptText="Dirección" />
                        <HBox spacing="10">
                           <children>
                              <Button onAction="#switchEditar" styleClass="btn-primary" text="Guardar Cambios" />
                              <Button onAction="#switchBuscar" styleClass="btn-secondary" text="Cancelar" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
            <Button fx:id="btnBuscar" onAction="#switchBuscar" styleClass="btn-primary" text="Buscar" />
            <Button fx:id="btnNuevo" onAction="#switchNuevo" styleClass="btn-secondary" text="Nuevo" />
            <Button fx:id="btnEditar" onAction="#switchEditar" styleClass="btn-secondary" text="Editar" />
         </children>
      </HBox>
      <TableView fx:id="tablaEmpresas">
         <columns>
            <TableColumn fx:id="colNombre" text="Nombre" />
            <TableColumn fx:id="colDireccion" text="Dirección" />
         </columns>
         <placeholder>
            <Label text="No hay alumnos registrados." />
         </placeholder>
      </TableView>
   </children>
</VBox>
