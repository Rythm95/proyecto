<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="card" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.GestionDatosPropiosController">
   <padding>
      <Insets bottom="15" left="15" right="15" top="15" />
   </padding>
   <children>
      <HBox spacing="10">
         <children>
            <HBox HBox.hgrow="ALWAYS">
               <children>
                  <VBox spacing="10" styleClass="form" HBox.hgrow="ALWAYS">
                     <children>
                        <TextField fx:id="txtEditNombre" promptText="Nombre" />
                        <Label fx:id="lblEditNombreError" managed="false" styleClass="error-label" visible="false" />
                        <TextField fx:id="txtEditEmail" promptText="Email" />
                        <Label fx:id="lblEditEmailError" managed="false" styleClass="error-label" visible="false" />
                        <TextField fx:id="txtEditUsername" promptText="Usuario" />
                        <Label fx:id="lblEditUsernameError" managed="false" styleClass="error-label" visible="false" />
                        <PasswordField fx:id="txtEditPassword" promptText="Contraseña" />
                        <Label fx:id="lblEditPasswordError" managed="false" styleClass="error-label" visible="false" />
                        <HBox spacing="10">
                           <children>
                              <Button onAction="#editar" styleClass="btn-primary" text="Guardar Cambios" />
                              <Button onAction="#cargarDatos" styleClass="btn-secondary" text="Cancelar" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>
   </children>
</VBox>
