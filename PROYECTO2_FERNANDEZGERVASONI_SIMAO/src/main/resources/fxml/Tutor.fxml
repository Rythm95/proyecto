<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" styleClass="root" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.TutorController">
	<top>
		<HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
			<padding>
				<Insets bottom="10" left="20" right="20" top="10" />
			</padding>
			<Label styleClass="title" text="Tutor de Empresa" />
			<Region HBox.hgrow="ALWAYS" />
			<Button styleClass="btn-primary" onAction="#logout" text="Cerrar Sesión" />
		</HBox>
	</top>
	<center>
		<TabPane tabClosingPolicy="UNAVAILABLE">
			<Tab text="Estudiantes">
				<VBox spacing="15" styleClass="card">
					<TableView fx:id="tablaEstudiantes">
						<columns>
							<TableColumn fx:id="colNombre" text="Nombre" />
							<TableColumn fx:id="colEmail" text="Email" />
							<TableColumn fx:id="colPeriodo" text="Periodo" />
						</columns>
					</TableView>
				</VBox>
			</Tab>
			<Tab text="Faltas">
				<VBox spacing="15" styleClass="card">
					<HBox spacing="10">
						<DatePicker fx:id="dateFalta" />
						<CheckBox fx:id="chkJustificada" text="Justificada" />
						<Button styleClass="btn-primary" text="Registrar falta" />
					</HBox>
					<TableView fx:id="tablaFaltas">
						<columns>
							<TableColumn fx:id="colFecha" text="Fecha" />
							<TableColumn fx:id="colJustificada" text="Justificada" />
						</columns>
					</TableView>
				</VBox>
			</Tab>
			<Tab text="Evaluación">
				<VBox spacing="15" styleClass="card">
					<Label styleClass="data-label" text="Calificación del estudiante" />
					<HBox spacing="10">
						<TextField fx:id="txtNota" promptText="Nota" />
						<Button styleClass="btn-primary" text="Guardar" />
					</HBox>
					<Label styleClass="data-label" text="Observaciones" />
					<TextArea fx:id="txtObservaciones" prefHeight="150" />
				</VBox>
			</Tab>
		</TabPane>
	</center>
</BorderPane>
