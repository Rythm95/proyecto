<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" styleClass="root" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.EstudianteController">
	<top>
		<HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         <Label styleClass="title" text="Estudiante" />
			<HBox HBox.hgrow="ALWAYS" />
			<Button styleClass="btn-primary" onAction="#logout" text="Cerrar Sesión" />
         </HBox>
	</top>

	<center>
		<TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
			<tabs>
				<Tab text="Mis datos">
					<content>
						<VBox styleClass="card" prefHeight="200.0" prefWidth="100.0">
							<Label text="Nombre:" />
							<TextField fx:id="txtNombre" promptText="Nombre" />
							<Label text="Email:" />
							<TextField fx:id="txtEmail" promptText="Email" />
							<Button text="Guardar cambios" />
						</VBox>
					</content>
				</Tab>
				<Tab text="Empresa">
					<content>
						<VBox styleClass="card" prefHeight="200.0" prefWidth="100.0">
							<Label fx:id="lblEmpresa" />
							<Label fx:id="lblTutorEmpresa" />
						</VBox>
					</content>
				</Tab>
				<Tab text="Formación">
					<content>
						<VBox styleClass="card" prefHeight="200.0" prefWidth="100.0">
							<Label fx:id="lblFechas" />
							<Label fx:id="lblPeriodo" />
							<Label fx:id="lblCalificacion" />
						</VBox>

					</content>
				</Tab>
				<Tab text="Faltas">
					<content>
						<VBox styleClass="card" prefHeight="200.0" prefWidth="100.0">
							<TableView fx:id="tablaFaltas">
								<columns>
									<TableColumn fx:id="colFecha" text="Fecha" />
									<TableColumn fx:id="colJustificada" text="Justificada" />
								</columns>
							</TableView>

							<Button text="Subir justificante" />
						</VBox>
					</content>
				</Tab>
			</tabs>
		</TabPane>
	</center>
</BorderPane>
