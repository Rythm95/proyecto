<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="1000.0"
	styleClass="root" stylesheets="@../styles/Styles.css"
	xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.simao.tarea3AD2024base.controller.AdminController">
	<top>
		<HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
			<padding>
				<Insets bottom="10" left="20" right="20" top="10" />
			</padding>
			<Label styleClass="title" text="Administración" />
			<HBox prefHeight="0.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
			<Button onAction="#logout" styleClass="btn-primary"
				text="Cerrar Sesión" />
		</HBox>
	</top>
	<center>
		<TabPane tabClosingPolicy="UNAVAILABLE">
			<Tab text="Profesorado">
				<VBox spacing="15" styleClass="card">
					<padding>
						<Insets bottom="15" left="15" right="15" top="15" />
					</padding>
					<HBox spacing="10">
						<HBox fx:id="boxBuscarProfe" HBox.hgrow="ALWAYS">
							<children>
								<TextField fx:id="txtBuscadorProfe"
									onAction="#buscarProfe" promptText="Buscar profesor..."
									HBox.hgrow="ALWAYS" />
							</children>
						</HBox>
						<HBox fx:id="boxNuevoProfe" managed="false" visible="false"
							HBox.hgrow="ALWAYS">
							<children>
								<VBox spacing="10" styleClass="form" HBox.hgrow="ALWAYS">
									<TextField fx:id="txtNombreProfe" promptText="Nombre" />
									<Label fx:id="lblNombreProfeError" managed="false"
										styleClass="error-label" visible="false" />
									<TextField fx:id="txtEmailProfe" promptText="Email" />
									<Label fx:id="lblEmailProfeError" managed="false"
										styleClass="error-label" visible="false" />
									<TextField fx:id="txtUsernameProfe"
										promptText="Usuario" />
									<Label fx:id="lblUsernameProfeError" managed="false"
										styleClass="error-label" visible="false" />
									<PasswordField fx:id="txtPasswordProfe"
										promptText="Contraseña" />
									<Label fx:id="lblPasswordProfeError" managed="false"
										styleClass="error-label" visible="false" />
									<HBox spacing="10">
										<Button onAction="#switchNuevoProfe"
											styleClass="btn-primary" text="Guardar" />
										<Button onAction="#switchBuscarProfe"
											styleClass="btn-secondary" text="Cancelar" />
									</HBox>
								</VBox>
							</children>
						</HBox>
						<HBox fx:id="boxEditarProfe" managed="false" visible="false"
							HBox.hgrow="ALWAYS">
							<children>
								<VBox spacing="10" styleClass="form" HBox.hgrow="ALWAYS">
									<children>
										<ComboBox fx:id="cbProfeEditar" prefWidth="250"
											promptText="Selecciona profesor" />
										<TextField fx:id="txtEditNombreProfe"
											promptText="Nombre" />
										<Label fx:id="lblEditNombreProfeError" managed="false"
											styleClass="error-label" visible="false" />
										<TextField fx:id="txtEditEmailProfe"
											promptText="Email" />
										<Label fx:id="lblEditEmailProfeError" managed="false"
											styleClass="error-label" visible="false" />
										<TextField fx:id="txtEditUsernameProfe"
											promptText="Usuario" />
										<Label fx:id="lblEditUsernameProfeError" managed="false"
											styleClass="error-label" visible="false" />
										<PasswordField fx:id="txtEditPasswordProfe"
											promptText="Contraseña" />
										<Label fx:id="lblEditPasswordProfeError" managed="false"
											styleClass="error-label" visible="false" />
										<HBox spacing="10">
											<children>
												<Button onAction="#switchEditarProfe"
													styleClass="btn-primary" text="Guardar Cambios" />
												<Button onAction="#switchBuscarProfe"
													styleClass="btn-secondary" text="Cancelar" />
											</children>
										</HBox>
									</children>
								</VBox>
							</children>
						</HBox>
						<Button fx:id="btnBuscarProfe"
							onAction="#switchBuscarProfe" styleClass="btn-primary"
							text="Buscar" />
						<Button fx:id="btnNuevoProfe" onAction="#switchNuevoProfe"
							styleClass="btn-secondary" text="Nuevo" />
						<Button fx:id="btnEditarProfe"
							onAction="#switchEditarProfe" styleClass="btn-secondary"
							text="Editar" />
					</HBox>
					<TableView fx:id="tablaProfes" VBox.vgrow="ALWAYS">
						<columns>
							<TableColumn fx:id="colNombreProfe" prefWidth="300"
								text="Nombre" />
							<TableColumn fx:id="colEmailProfe" prefWidth="300"
								text="Email" />
						</columns>
						<placeholder>
							<Label text="No hay profesores registrados." />
						</placeholder>
					</TableView>
				</VBox>
			</Tab>
			<Tab text="Cursos">
				<VBox spacing="15" styleClass="card">
					<padding>
						<Insets bottom="15" left="15" right="15" top="15" />
					</padding>
					<HBox spacing="10" VBox.vgrow="NEVER">
						<ComboBox fx:id="cbCoordinador" prefWidth="250"
							promptText="Selecciona profesor" />
						<Button onAction="#asignarCoordinador"
							styleClass="btn-primary" text="Asignar Coordinador" />
					</HBox>
					<TableView fx:id="tablaCursos" VBox.vgrow="ALWAYS">
						<columns>
							<TableColumn fx:id="colCodigo" prefWidth="150"
								text="Código" />
							<TableColumn fx:id="colCiclo" prefWidth="200"
								text="Ciclo" />
							<TableColumn fx:id="colCurso" prefWidth="80"
								text="Curso" />
							<TableColumn fx:id="colCoordinador" prefWidth="250"
								text="Coordinador" />
						</columns>
						<placeholder>
							<Label text="No hay cursos registrados." />
						</placeholder>
					</TableView>
				</VBox>
			</Tab>
			<Tab text="Módulos">
				<VBox spacing="15" styleClass="card">
					<padding>
						<Insets bottom="15" left="15" right="15" top="15" />
					</padding>
					<HBox spacing="10">
						<HBox fx:id="boxAsignacionModulo" managed="false"
							spacing="10.0" visible="false" HBox.hgrow="ALWAYS">
							<children>
								<ComboBox fx:id="cbCurso" prefWidth="200"
									promptText="Selecciona curso" />
								<ComboBox fx:id="cbProfesorModulo" prefWidth="250"
									promptText="Selecciona profesor" />
							</children>
						</HBox>
						<HBox fx:id="boxCreacionModulo" spacing="10.0"
							HBox.hgrow="ALWAYS">
							<children>
								<VBox HBox.hgrow="ALWAYS">
									<children>
										<TextField fx:id="txtNombreModulo"
											onAction="#switchNuevoModulo"
											promptText="Nombre del módulo..." />
										<Label fx:id="lblNombreModuloError" managed="false"
											styleClass="error-label" text="" visible="false" />
									</children>
								</VBox>
							</children>
						</HBox>
						<HBox fx:id="boxEdicionModulo" managed="false" spacing="10.0"
							visible="false" HBox.hgrow="ALWAYS">
							<children>
								<VBox HBox.hgrow="ALWAYS">
									<children>
										<TextField fx:id="txtEditNombreModulo"
											onAction="#switchEditarModulo"
											promptText="Nombre del módulo..." />
										<Label fx:id="lblEditNombreModuloError" managed="false"
											styleClass="error-label" text="" visible="false" />
									</children>
								</VBox>
								<ComboBox fx:id="cbModuloEditar" prefWidth="250"
									promptText="Selecciona módulo" />
							</children>
						</HBox>
						<Button fx:id="btnCrearModulo"
							onAction="#switchNuevoModulo" styleClass="btn-primary"
							text="Nuevo" />
						<Button fx:id="btnAsignarModulo"
							onAction="#switchAsignarModulo" styleClass="btn-secondary"
							text="Asignar" />
						<Button fx:id="btnEditarModulo"
							onAction="#switchEditarModulo" styleClass="btn-secondary"
							text="Editar" />
					</HBox>
					<TableView fx:id="tablaModulos" VBox.vgrow="ALWAYS">
						<columns>
							<TableColumn fx:id="colModulo" prefWidth="250"
								text="Módulo" />
							<TableColumn fx:id="colCursoModulo" prefWidth="150"
								text="Curso" />
							<TableColumn fx:id="colProfesorModulo"
								prefWidth="250" text="Profesor" />
						</columns>
						<placeholder>
							<Label text="No hay módulos registrados." />
						</placeholder>
					</TableView>
				</VBox>
			</Tab>
			<Tab text="Alumnos">
				<content>
					<fx:include source="GestionAlumno.fxml" />
				</content>
			</Tab>
			<Tab text="Empresas">
				<content>
					<fx:include source="GestionEmpresa.fxml" />
				</content>
			</Tab>
		</TabPane>
	</center>
</BorderPane>
