<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="1000.0"
            stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="root" fx:controller="com.simao.tarea3AD2024base.controller.AdminController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
            <padding>
                <Insets top="10" bottom="10" left="20" right="20"/>
            </padding>
            <Label text="Administración" styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Cerrar Sesión" onAction="#logout" styleClass="btn-primary"/>
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <Tab text="Tutores">
                <VBox spacing="15" styleClass="card">
                    <HBox spacing="10">
                        <TextField promptText="Buscar tutor..." HBox.hgrow="ALWAYS"/>
                        <Button text="Nuevo" styleClass="btn-primary"/>
                        <Button text="Eliminar" styleClass="btn-secondary"/>
                    </HBox>
                    <TableView fx:id="tablaTutores">
                        <columns>
                            <TableColumn text="Nombre" fx:id="colNombreTutor"/>
                            <TableColumn text="Email" fx:id="colEmailTutor"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="Cursos">
                <VBox spacing="15" styleClass="card">
                    <HBox spacing="10">
                        <TextField promptText="Buscar curso..." HBox.hgrow="ALWAYS"/>
                        <Button text="Nuevo" styleClass="btn-primary"/>
                        <Button text="Eliminar" styleClass="btn-secondary"/>
                    </HBox>
                    <TableView fx:id="tablaCursos">
                        <columns>
                            <TableColumn text="Código" fx:id="colCodigo"/>
                            <TableColumn text="Ciclo" fx:id="colCiclo"/>
                            <TableColumn text="Curso" fx:id="colCurso"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="Asignaciones">
                <VBox spacing="15" styleClass="card">
                    <Label text="Asignar tutor a curso" styleClass="data-label"/>
                    <HBox spacing="10">
                        <ComboBox fx:id="comboTutores" promptText="Seleccionar tutor"/>
                        <ComboBox fx:id="comboCursos" promptText="Seleccionar curso"/>
                        <Button text="Asignar" styleClass="btn-primary"/>
                    </HBox>
                    <TableView fx:id="tablaAsignaciones">
                        <columns>
                            <TableColumn text="Tutor" fx:id="colTutorAsignado"/>
                            <TableColumn text="Curso" fx:id="colCursoAsignado"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>