<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" styleClass="root" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.simao.tarea3AD2024base.controller.AdminController">
	<top>
		<HBox alignment="CENTER_LEFT" spacing="10" styleClass="header">
			<padding>
				<Insets bottom="10" left="20" right="20" top="10" />
			</padding>
			<Label styleClass="title" text="Administración" />
			<Region HBox.hgrow="ALWAYS" />
			<Button onAction="#logout" styleClass="btn-primary" text="Cerrar Sesión" />
		</HBox>
	</top>
	<center>
		<TabPane tabClosingPolicy="UNAVAILABLE">
			<Tab text="Profesorado">
				<VBox spacing="15" styleClass="card">
					<padding>
						<Insets bottom="15" left="15" right="15" top="15" />
					</padding>
					<HBox spacing="10">
						<TextField fx:id="buscadorProfe" onAction="#buscarProfe" promptText="Buscar profesor..." HBox.hgrow="ALWAYS" />
						<Button onAction="#buscarProfe" styleClass="btn-secondary" text="Buscar" />
						<Button onAction="#switchFormTutor" styleClass="btn-primary" text="Nuevo" />
						<Button styleClass="btn-secondary" text="Editar" />
					</HBox>
					<TableView fx:id="tablaProfes" VBox.vgrow="ALWAYS">
						<columns>
							<TableColumn fx:id="colNombreProfe" prefWidth="300" text="Nombre" />
							<TableColumn fx:id="colEmailProfe" prefWidth="300" text="Email" />
						</columns>
						<placeholder>
							<Label text="No hay tutores registrados." />
						</placeholder>
					</TableView>
					<VBox fx:id="formProfe" managed="false" spacing="10" styleClass="form" visible="false">

						<Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Nuevo Profesor" />

						<TextField fx:id="txtNombreProfe" promptText="Nombre" />

						<TextField fx:id="txtEmailProfe" promptText="Email" />

						<TextField fx:id="txtUsernameProfe" promptText="Usuario" />

						<PasswordField fx:id="txtPasswordProfe" promptText="Contraseña" />

						<HBox spacing="10">

							<Button onAction="#guardarProfe" styleClass="btn-primary" text="Guardar" />

							<Button onAction="#switchFormTutor" styleClass="btn-secondary" text="Cancelar" />

						</HBox>

					</VBox>
				</VBox>
			</Tab>
			<Tab text="Cursos">
				<VBox spacing="15" styleClass="card">
					<padding>
						<Insets bottom="15" left="15" right="15" top="15" />
					</padding>
					<HBox spacing="10">
						<TextField fx:id="buscadorCurso" promptText="Buscar curso o ciclo..." HBox.hgrow="ALWAYS" />
						<Button styleClass="btn-secondary" text="Buscar" />
						<Button styleClass="btn-primary" text="Nuevo" />
						<Button styleClass="btn-secondary" text="Editar" />
					</HBox>
					<TableView fx:id="tablaCursos" VBox.vgrow="ALWAYS">
						<columns>
							<TableColumn fx:id="colCodigo" prefWidth="150" text="Código" />
							<TableColumn fx:id="colCiclo" prefWidth="200" text="Ciclo" />
							<TableColumn fx:id="colCurso" prefWidth="80" text="Curso" />
						</columns>
						<placeholder>
							<Label text="No hay cursos registrados." />
						</placeholder>
					</TableView>
				</VBox>
			</Tab>
			<Tab text="Asignaciones">
				<VBox spacing="15" styleClass="card">
					<padding>
						<Insets bottom="15" left="15" right="15" top="15" />
					</padding>
					<Label styleClass="data-label" text="Asignar tutor a curso" />
					<HBox alignment="CENTER_LEFT" spacing="10">
						<ComboBox fx:id="comboProfes" prefWidth="250" promptText="Seleccionar tutor" />
						<ComboBox fx:id="comboCursos" prefWidth="250" promptText="Seleccionar curso" />
						<Button styleClass="btn-primary" text="Asignar" />
					</HBox>
					<TableView fx:id="tablaAsignaciones" VBox.vgrow="ALWAYS">
						<columns>
							<TableColumn fx:id="colProfeAsignado" prefWidth="300" text="Tutor" />
							<TableColumn fx:id="colCursoAsignado" prefWidth="350" text="Curso" />
						</columns>
						<placeholder>
							<Label text="No hay asignaciones." />
						</placeholder>
					</TableView>
				</VBox>
			</Tab>
		</TabPane>
	</center>
</BorderPane>
